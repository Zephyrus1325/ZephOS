  {
      "version": "0.2.0",
      "configurations": [
            {
                "name": "Run Program",
                "type": "cppdbg",
                "request": "launch",
                "program": "${workspaceFolder}/kernel.elf",
                "cwd": "${workspaceFolder}",
                "MIMode": "gdb",
                "miDebuggerPath": "arm-none-eabi-gdb.exe",
                "miDebuggerServerAddress": "localhost:1234",
                "serverLaunchTimeout": 5000, // Aumentado para 5 segundos
                "stopAtEntry": true,
                "preLaunchTask": "Debug Program"
            }
      ]
  }