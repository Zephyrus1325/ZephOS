{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Program",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/kernel.elf",
      "cwd": "${workspaceFolder}",
      "MIMode": "gdb",
      "miDebuggerPath": "arm-none-eabi-gdb.exe",
      "miDebuggerServerAddress": "localhost:1234",
      "serverLaunchTimeout": 5000,
      "stopAtEntry": true,
      "preLaunchTask": "Debug Program"
    },
    {
      "name": "C/C++ Runner: Debug Session",
      "type": "cppdbg",
      "request": "launch",
      "args": [],
      "stopAtEntry": false,
      "externalConsole": true,
      "cwd": "${workspaceFolder}/core",
      "program": "${workspaceFolder}/core/build/Debug/outDebug",
      "MIMode": "gdb",
      "miDebuggerPath": "gdb",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    }
  ]
}